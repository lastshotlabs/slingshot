{
  "manifestVersion": 1,
  "port": 3000,
  "security": {
    "signing": { "secret": "${secret:JWT_SECRET}" }
  },
  "plugins": [
    {
      "plugin": "slingshot-auth",
      "config": {
        "auth": { "roles": ["user", "moderator", "admin"], "defaultRole": "user" },
        "db": { "auth": "memory", "sessions": "memory", "oauthState": "memory" }
      }
    },
    {
      "plugin": "slingshot-notifications",
      "config": {
        "dispatcher": { "enabled": false }
      }
    },
    {
      "plugin": "slingshot-permissions",
      "config": {
        "adapter": "memory"
      }
    },
    {
      "plugin": "slingshot-community",
      "config": {
        "authBridge": "auto",
        "containerCreation": "user"
      }
    },
    {
      "plugin": "slingshot-chat",
      "config": {
        "storeType": "memory",
        "permissions": {
          "createRoom": ["user", "moderator", "admin"],
          "sendMessage": ["user", "moderator", "admin"]
        }
      }
    },
    {
      "plugin": "slingshot-polls",
      "config": {}
    },
    {
      "plugin": "slingshot-assets",
      "config": {
        "storage": { "adapter": "memory" },
        "presignedUrls": true,
        "allowedMimeTypes": ["image/png", "image/jpeg", "image/gif", "image/webp"],
        "image": { "allowedOrigins": ["localhost"] }
      }
    },
    {
      "plugin": "slingshot-emoji",
      "config": {}
    },
    {
      "plugin": "slingshot-embeds",
      "config": {}
    },
    {
      "plugin": "slingshot-gifs",
      "config": {
        "provider": "tenor",
        "apiKey": "${secret:TENOR_API_KEY}",
        "rating": "pg"
      }
    },
    {
      "plugin": "slingshot-deep-links",
      "config": {
        "fallbackBaseUrl": "https://app.example.com",
        "fallbackRedirects": {
          "/join/*": "/workspace/:id",
          "/share/*": "/thread/:id"
        }
      }
    },
    {
      "plugin": "slingshot-interactions",
      "config": {
        "handlers": {
          "polls:vote:": { "kind": "route", "target": "/internal/interactions/poll-vote" },
          "chat:pin:": { "kind": "queue", "target": "jobs:chat.pin", "fireAndForget": true }
        }
      }
    }
  ]
}
