{
  "name": "@slingshot/runtime-bun",
  "version": "0.0.1",
  "description": "Bun-native runtime implementation for Slingshot",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "repository": {
    "type": "git",
