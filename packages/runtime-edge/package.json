{
  "name": "@lastshotlabs/slingshot-runtime-edge",
  "version": "0.0.1",
  "description": "Edge runtime implementation with Web Crypto and KV-backed ISR for Slingshot",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./kv": {
      "types": "./dist/kv-isr.d.ts",
      "import": "./dist/kv-isr.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/runtime-edge"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src/ --cache",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*",
    "@lastshotlabs/slingshot-ssr": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@lastshotlabs/slingshot-ssr": {
      "optional": true
    }
  },
  "devDependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*",
    "@lastshotlabs/slingshot-ssr": "workspace:*",
    "typescript": "*"
  }
}
