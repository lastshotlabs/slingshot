{
  "compilerOptions": {
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2022",
    "types": ["bun"],
    "lib": ["ES2022", "DOM"],
    "paths": {
      "@lastshotlabs/slingshot-core": ["../slingshot-core/src/index.ts"],
      "@lastshotlabs/slingshot-ssr": ["../slingshot-ssr/src/index.ts"]
    }
  },
  "include": ["src/**/*", "tests/**/*"]
}
