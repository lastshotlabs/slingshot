{
  "name": "@lastshotlabs/slingshot-runtime-node",
  "version": "0.2.2",
  "description": "Node.js runtime implementation for Slingshot",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./testing": {
      "types": "./dist/src/testing.d.ts",
      "import": "./dist/src/testing.js"
    },
    "./errors": {
      "types": "./dist/src/errors.d.ts",
      "import": "./dist/src/errors.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/runtime-node"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src/ --cache",
    "test": "bun run test:vitest",
    "coverage": "bun test --coverage",
    "test:vitest": "vitest run --config vitest.config.ts",
    "test:integration": "vitest run --config vitest.config.ts tests/integration/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*"
  },
  "peerDependencies": {
    "@hono/node-server": ">=2.0.5 <3",
    "argon2": ">=0.31",
    "better-sqlite3": ">=9.0",
    "fast-glob": ">=3.0",
    "ws": ">=8.20.1 <9"
  },
  "peerDependenciesMeta": {
    "@hono/node-server": {
      "optional": false
    },
    "argon2": {
      "optional": false
    },
    "better-sqlite3": {
      "optional": false
    },
    "fast-glob": {
      "optional": false
    },
    "ws": {
      "optional": false
    }
  },
  "devDependencies": {
    "@hono/node-server": "2.0.11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.18.1",
    "ws": "8.21.1",
    "typescript": "*"
  },
  "engines": {
    "node": ">=20"
  }
}
