{
  "name": "@lastshotlabs/slingshot-ai",
  "version": "0.2.0",
  "description": "Multi-provider LLM capability for Slingshot — generation, structured output, moderation, cost tracking",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./testing": {
      "bun": "./dist/src/testing.js",
      "types": "./dist/src/testing.d.ts",
      "import": "./dist/src/testing.js"
    },
    "./orchestration": {
      "bun": "./dist/src/orchestration.js",
      "types": "./dist/src/orchestration.d.ts",
      "import": "./dist/src/orchestration.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-ai"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --cache"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*",
    "@lastshotlabs/slingshot-entity": "workspace:*"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30",
    "@lastshotlabs/slingshot-orchestration": "workspace:*",
    "@lastshotlabs/slingshot-orchestration-engine": "workspace:*",
    "zod": ">=4.0 <5"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@lastshotlabs/slingshot-orchestration": {
      "optional": true
    },
    "@lastshotlabs/slingshot-orchestration-engine": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  }
}
