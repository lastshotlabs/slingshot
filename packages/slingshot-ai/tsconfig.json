{
  // Extends the root config so the workspace path aliases (@framework/*,
  // @lastshotlabs/*, ...) resolve. The integration test boots a real app via
  // `tests/setup`, which reaches into the root `src/`; without the root paths a
  // package-local typecheck drowns in unresolved-module noise and stops being a
  // useful gate (as it currently does in several sibling packages).
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ESNext",
    "types": ["bun"],
    "noEmit": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
