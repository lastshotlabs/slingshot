{
  "name": "@lastshotlabs/slingshot-assets",
  "version": "0.0.1",
  "description": "Entity-backed asset storage, upload metadata, and storage adapter resolution for Slingshot",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./testing": {
      "bun": "./src/testing/index.ts",
      "types": "./dist/src/testing/index.d.ts",
      "import": "./dist/src/testing/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-assets"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --cache"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*",
    "@lastshotlabs/slingshot-entity": "workspace:*",
    "@lastshotlabs/slingshot-permissions": "workspace:*"
  },
  "optionalDependencies": {
    "sharp": ">=0.33"
  },
  "peerDependencies": {
    "hono": ">=4.12.12 <5",
    "zod": ">=4.0 <5"
  },
  "peerDependenciesMeta": {
    "sharp": {
      "optional": true
    },
    "@aws-sdk/client-s3": {
      "optional": true
    },
    "@aws-sdk/s3-request-presigner": {
      "optional": true
    },
    "@aws-sdk/lib-storage": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  }
}
