{
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ESNext",
    "types": ["bun"],
    "paths": {
      "@auth/*": ["./src/*"],
      "@lastshotlabs/slingshot-core": ["../slingshot-core/src/index.ts"],
      "@lastshotlabs/slingshot-auth": ["./src/index.ts"],
      "@lastshotlabs/slingshot-organizations": ["../slingshot-organizations/src/index.ts"],
      "@lastshotlabs/slingshot-m2m": ["../slingshot-m2m/src/index.ts"],
      "@lastshotlabs/slingshot-scim": ["../slingshot-scim/src/index.ts"],
      "@lastshotlabs/slingshot-oidc": ["../slingshot-oidc/src/index.ts"],
      "@lastshotlabs/slingshot-auth/plugin": ["./src/plugin-api.ts"],
      "@lastshotlabs/slingshot-auth/testing": ["./src/testing.ts"],
      "@slingshot/runtime-bun": ["../runtime-bun/src/index.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
