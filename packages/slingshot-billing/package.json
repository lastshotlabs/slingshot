{
  "name": "@lastshotlabs/slingshot-billing",
  "version": "0.1.0",
  "description": "Provider-abstracted billing for Slingshot: subscriptions, trials, donations, and an app-agnostic entitlement surface",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": { "bun": "./dist/src/index.js", "types": "./dist/src/index.d.ts", "import": "./dist/src/index.js" },
    "./public": { "bun": "./dist/src/public.js", "types": "./dist/src/public.d.ts", "import": "./dist/src/public.js" },
    "./config": { "bun": "./dist/src/types/config.js", "types": "./dist/src/types/config.d.ts", "import": "./dist/src/types/config.js" }
  },
  "repository": { "type": "git", "url": "https://github.com/lastshotlabs/slingshot.git", "directory": "packages/slingshot-billing" },
  "publishConfig": { "registry": "https://npm.pkg.github.com", "access": "public" },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests",
    "test:unit": "bun test tests/unit",
    "lint": "eslint src/ --cache"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*",
    "@lastshotlabs/slingshot-entity": "workspace:*",
    "zod": ">=4.0 <5"
  },
  "peerDependencies": { "hono": ">=4.12.14 <5" },
  "engines": { "node": ">=20" }
}
