{
  "name": "@lastshotlabs/slingshot-bullmq",
  "version": "0.0.1",
  "description": "Durable BullMQ-backed event bus adapter for Slingshot",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-bullmq"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "bun run build",
    "lint": "eslint src/ --cache",
    "test": "cd ../.. && bun test tests/unit/bullmq-adapter.test.ts && bun test tests/isolated/bullmq-adapter-durable.test.ts",
    "test:redis": "cd ../.. && BULLMQ_INTEGRATION_REDIS_URL=redis://localhost:6380 bun test tests/docker/bullmq-adapter-redis-integration.test.ts"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*"
  },
  "peerDependencies": {
    "bullmq": ">=5",
    "ioredis": ">=5",
    "zod": ">=4.0 <5"
  },
  "peerDependenciesMeta": {
    "bullmq": {
      "optional": false
    },
    "ioredis": {
      "optional": false
    }
  },
  "devDependencies": {
    "bullmq": "^5.70.4",
    "ioredis": "5.10.0"
  }
}
