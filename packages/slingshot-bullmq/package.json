{
  "name": "@lastshotlabs/slingshot-bullmq",
  "version": "0.2.0",
  "description": "Durable BullMQ-backed event bus adapter for Slingshot",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./testing": {
      "bun": "./dist/src/testing.js",
      "types": "./dist/src/testing.d.ts",
      "import": "./dist/src/testing.js"
    },
    "./errors": {
      "bun": "./dist/src/errors.js",
      "types": "./dist/src/errors.d.ts",
      "import": "./dist/src/errors.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-bullmq"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --cache",
    "test": "bun test",
    "coverage": "bun test --coverage",
    "test:unit": "bun test --ignore tests/integration --ignore tests/helpers",
    "test:integration": "bun test tests/integration",
    "test:redis": "cd ../.. && BULLMQ_INTEGRATION_REDIS_URL=redis://localhost:6380 bun test tests/docker/bullmq-adapter-redis-integration.test.ts",
    "bench": "bun run tests/bench/emit-throughput.bench.ts"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*"
  },
  "peerDependencies": {
    "bullmq": ">=5 <6",
    "ioredis": ">=5 <6",
    "zod": ">=4.0 <5"
  },
  "peerDependenciesMeta": {
    "bullmq": {
      "optional": false
    },
    "ioredis": {
      "optional": false
    }
  },
  "devDependencies": {
    "bullmq": "^5.76.4",
    "ioredis": "5.10.0"
  },
  "engines": {
    "node": ">=20"
  }
}
