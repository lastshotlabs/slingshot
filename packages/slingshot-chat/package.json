{
  "name": "@lastshotlabs/slingshot-chat",
  "version": "0.1.0",
  "description": "Real-time chat with rooms, messages, membership, and encryption for Slingshot",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./testing": {
      "bun": "./src/testing/index.ts",
      "types": "./dist/src/testing/index.d.ts",
      "import": "./dist/src/testing/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-chat"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --cache",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "^0.1.0",
    "@lastshotlabs/slingshot-entity": "workspace:*",
    "@lastshotlabs/slingshot-notifications": "workspace:*"
  },
  "peerDependencies": {
    "@lastshotlabs/slingshot-permissions": "workspace:*",
    "hono": ">=4.12.12 <5",
    "zod": ">=4.0 <5"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  }
}
