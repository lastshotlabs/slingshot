{
  "name": "@lastshotlabs/slingshot-core",
  "version": "0.0.2",
  "description": "Core plugin contract, context, event bus, and shared types for Slingshot",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./testing": {
      "bun": "./src/testing.ts",
      "types": "./dist/src/testing.d.ts",
      "import": "./dist/src/testing.js"
    },
    "./content": {
      "bun": "./src/content.public.ts",
      "types": "./dist/src/content.public.d.ts",
      "import": "./dist/src/content.public.js"
    },
    "./faker": {
      "bun": "./src/faker/index.ts",
      "types": "./dist/src/faker/index.d.ts",
      "import": "./dist/src/faker/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-core"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --cache"
  },
  "dependencies": {
    "@faker-js/faker": ">=10.0",
    "@hono/zod-openapi": ">=0.18",
    "@asteasolutions/zod-to-openapi": ">=7.0"
  },
  "peerDependencies": {
    "hono": ">=4.12.12 <5",
    "zod": ">=4.0 <5"
  },
  "devDependencies": {
    "@types/pg": "^8.18.0"
  }
}
