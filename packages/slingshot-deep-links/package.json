{
  "name": "@lastshotlabs/slingshot-deep-links",
  "version": "0.0.2",
  "description": "Universal links, Android app links, and fallback redirects for slingshot",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./schema.json": "./schema.json",
    "./testing": {
      "bun": "./src/testing.ts",
      "types": "./dist/src/testing.d.ts",
      "import": "./dist/src/testing.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-deep-links"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist",
    "schema.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --cache"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*",
    "zod": ">=4.0 <5"
  },
  "peerDependencies": {
    "hono": ">=4.12.12 <5"
  },
  "engines": {
    "node": ">=20"
  }
}
