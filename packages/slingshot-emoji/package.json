{
  "name": "@lastshotlabs/slingshot-emoji",
  "version": "0.0.2",
  "description": "Custom emoji management for slingshot — CRUD with storage integration",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-emoji"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --cache"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*",
    "@lastshotlabs/slingshot-entity": "workspace:*"
  },
  "peerDependencies": {
    "@hono/zod-openapi": ">=0.18",
    "hono": ">=4.12.12 <5",
    "zod": ">=4.0 <5",
    "drizzle-orm": ">=0.45.2 <1",
    "mongoose": ">=9.0 <10",
    "pg": "^8.20.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  }
}
