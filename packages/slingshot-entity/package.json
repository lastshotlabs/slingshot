{
  "name": "@lastshotlabs/slingshot-entity",
  "version": "0.0.2",
  "description": "Config-driven entity CRUD, code generation, and search for Slingshot",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./routing": {
      "bun": "./dist/src/routing/index.js",
      "types": "./dist/src/routing/index.d.ts",
      "import": "./dist/src/routing/index.js"
    },
    "./seeder": {
      "bun": "./dist/src/seeder/index.js",
      "types": "./dist/src/seeder/index.d.ts",
      "import": "./dist/src/seeder/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-entity"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --cache"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*"
  },
  "peerDependencies": {
    "@hono/zod-openapi": ">=0.18",
    "hono": ">=4.12.12 <5",
    "zod": ">=4.0 <5"
  },
  "engines": {
    "node": ">=20"
  }
}
