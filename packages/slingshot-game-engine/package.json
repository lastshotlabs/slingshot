{
  "name": "@lastshotlabs/slingshot-game-engine",
  "version": "0.0.3",
  "description": "Multiplayer game state engine plugin for slingshot",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./types": {
      "bun": "./dist/src/types/models.js",
      "types": "./dist/src/types/models.d.ts",
      "import": "./dist/src/types/models.js"
    },
    "./recipes": {
      "bun": "./dist/src/recipes/index.js",
      "types": "./dist/src/recipes/index.d.ts",
      "import": "./dist/src/recipes/index.js"
    },
    "./testing": {
      "bun": "./dist/src/testing/index.js",
      "types": "./dist/src/testing/index.d.ts",
      "import": "./dist/src/testing/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-game-engine"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src/ --cache",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*",
    "@lastshotlabs/slingshot-entity": "workspace:*",
    "zod": ">=4.0 <5"
  },
  "peerDependencies": {
    "hono": ">=4.12.14 <5"
  },
  "engines": {
    "node": ">=20"
  }
}
