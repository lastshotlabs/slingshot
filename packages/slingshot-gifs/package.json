{
  "name": "@lastshotlabs/slingshot-gifs",
  "version": "0.0.1",
  "description": "GIF search proxy for slingshot — swappable providers (Giphy, Tenor), server-side API key",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-gifs"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --cache",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*"
  }
}
