{
  "name": "@lastshotlabs/slingshot-m2m",
  "version": "0.0.2",
  "description": "Machine-to-machine (M2M) OAuth2 client credentials plugin for Slingshot",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-m2m"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src/ --cache",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*"
  },
  "peerDependencies": {
    "@lastshotlabs/slingshot-auth": "workspace:*",
    "hono": ">=4.12.12 <5",
    "zod": ">=4.0 <5",
    "mongoose": ">=9.0 <10"
  },
  "peerDependenciesMeta": {
    "@lastshotlabs/slingshot-auth": {
      "optional": false
    },
    "mongoose": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  }
}
