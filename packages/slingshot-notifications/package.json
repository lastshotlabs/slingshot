{
  "name": "@lastshotlabs/slingshot-notifications",
  "version": "0.1.0",
  "description": "Shared notification storage, scheduling, and delivery events for slingshot",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./testing": {
      "bun": "./src/testing.ts",
      "types": "./dist/src/testing.d.ts",
      "import": "./dist/src/testing.js"
    },
    "./rateLimit": {
      "bun": "./src/rateLimit/index.ts",
      "types": "./dist/src/rateLimit/index.d.ts",
      "import": "./dist/src/rateLimit/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests",
    "lint": "eslint src/ --cache",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "^0.1.0",
    "@lastshotlabs/slingshot-entity": "workspace:*",
    "zod": ">=4.0 <5"
  },
  "peerDependencies": {
    "hono": ">=4.12.12 <5"
  }
}
