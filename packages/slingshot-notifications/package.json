{
  "name": "@lastshotlabs/slingshot-notifications",
  "version": "0.0.2",
  "description": "Shared notification storage, scheduling, and delivery events for slingshot",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./testing": {
      "bun": "./dist/src/testing.js",
      "types": "./dist/src/testing.d.ts",
      "import": "./dist/src/testing.js"
    },
    "./rateLimit": {
      "bun": "./dist/src/rateLimit/index.js",
      "types": "./dist/src/rateLimit/index.d.ts",
      "import": "./dist/src/rateLimit/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-notifications"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test tests",
    "lint": "eslint src/ --cache"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*",
    "@lastshotlabs/slingshot-entity": "workspace:*",
    "zod": ">=4.0 <5"
  },
  "peerDependencies": {
    "hono": ">=4.12.12 <5"
  },
  "engines": {
    "node": ">=20"
  }
}
