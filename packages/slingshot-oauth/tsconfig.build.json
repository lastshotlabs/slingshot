{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "noCheck": true,
    "declaration": true,
    "outDir": "dist",

    "tsBuildInfoFile": ".tmp/tsconfig.build.tsbuildinfo",
    "rootDir": ".",
    "skipLibCheck": true,
    "paths": {
      "@lastshotlabs/slingshot-core": ["../slingshot-core/dist/src/index.d.ts"],
      "@lastshotlabs/slingshot-auth": ["../slingshot-auth/dist/src/index.d.ts"],
      "@lastshotlabs/slingshot-auth/plugin": ["../slingshot-auth/dist/src/plugin-api.d.ts"],
      "@lastshotlabs/slingshot-auth/testing": ["../slingshot-auth/dist/src/testing.d.ts"]
    },
    "composite": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
