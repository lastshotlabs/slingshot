{
  "name": "@lastshotlabs/slingshot-oidc",
  "version": "0.0.2",
  "description": "OIDC discovery and JWKS plugin for Slingshot",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-oidc"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
