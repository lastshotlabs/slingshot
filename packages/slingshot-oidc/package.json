    "zod": ">=4.0 <5",
    "jose": ">=6.0"
  },
  "peerDependenciesMeta": {
    "@lastshotlabs/slingshot-auth": {
      "optional": false
    }
  },
  "engines": {
    "node": ">=20"
  }
