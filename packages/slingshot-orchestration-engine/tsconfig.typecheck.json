{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    "tsBuildInfoFile": ".tmp/tsconfig.typecheck.tsbuildinfo",
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": ".",
    "outDir": ".tmp/typecheck/src",
    "noEmit": false
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"],
  // Required now that the base config carries the workspace `paths`: without a
  // project reference, TypeScript would pull slingshot-core's SOURCE into this
  // project (it is outside our rootDir) instead of consuming its declarations.
  "references": [
    {
      "path": "../slingshot-core/tsconfig.typecheck.json"
    }
  ]
}
