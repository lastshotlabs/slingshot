{
  "name": "@lastshotlabs/slingshot-orchestration-plugin",
  "version": "0.0.2",
  "description": "Slingshot plugin, context helpers, and HTTP routes for the portable orchestration runtime",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-orchestration-plugin"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --cache"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*",
    "@lastshotlabs/slingshot-orchestration": "workspace:*"
  },
  "peerDependencies": {
    "hono": ">=4.12.14 <5",
    "zod": ">=4.0 <5"
  },
  "engines": {
    "node": ">=20"
  }
}
