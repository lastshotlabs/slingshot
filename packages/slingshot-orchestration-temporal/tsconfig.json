{
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ESNext",
    "types": ["bun", "node"],
    "paths": {
      "@lastshotlabs/slingshot-orchestration-engine": [
        "../slingshot-orchestration-engine/src/index.ts"
      ],
      "@lastshotlabs/slingshot-orchestration-engine/provider": [
        "../slingshot-orchestration-engine/src/provider/index.ts"
      ]
    },
    "skipLibCheck": true
  },
  "exclude": ["dist", "node_modules"]
}
