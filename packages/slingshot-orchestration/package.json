{
  "name": "@lastshotlabs/slingshot-orchestration",
  "version": "0.0.2",
  "description": "Portable orchestration runtime, task/workflow DSL, and built-in memory/SQLite adapters for Slingshot",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./errors": {
      "bun": "./src/errors.ts",
      "types": "./dist/src/errors.d.ts",
      "import": "./dist/src/errors.js"
    },
    "./provider": {
      "bun": "./src/provider/index.ts",
      "types": "./dist/src/provider/index.d.ts",
      "import": "./dist/src/provider/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-orchestration"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --cache"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "peerDependencies": {
    "zod": ">=4.0 <5"
  },
  "engines": {
    "node": ">=20"
  }
}
