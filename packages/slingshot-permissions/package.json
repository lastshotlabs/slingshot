{
  "name": "@lastshotlabs/slingshot-permissions",
  "version": "0.1.1",
  "description": "Policy engine for slingshot — grants, roles, tenant-scoped permission evaluation",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./testing": {
      "bun": "./src/testing.ts",
      "types": "./dist/src/testing.d.ts",
      "import": "./dist/src/testing.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-permissions"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --cache",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "^0.1.0"
  },
  "peerDependencies": {
    "pg": "^8.20.0",
    "mongoose": ">=9.0 <10"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    }
  }
}
