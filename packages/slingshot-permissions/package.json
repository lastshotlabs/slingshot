{
  "name": "@lastshotlabs/slingshot-permissions",
  "version": "0.0.2",
  "description": "Policy engine for slingshot — grants, roles, tenant-scoped permission evaluation",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./testing": {
      "bun": "./dist/src/testing.js",
      "types": "./dist/src/testing.d.ts",
      "import": "./dist/src/testing.js"
    },
    "./errors": {
      "bun": "./dist/src/errors.js",
      "types": "./dist/src/errors.d.ts",
      "import": "./dist/src/errors.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-permissions"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "coverage": "bun test --coverage",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --cache",
    "bench": "bun run tests/bench/evaluate-throughput.bench.ts"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*"
  },
  "peerDependencies": {
    "pg": "^8.20.0",
    "mongoose": ">=9.0 <10"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  }
}
