{
  "name": "@lastshotlabs/slingshot-postgres",
  "version": "0.0.2",
  "description": "Postgres adapter and connection helper for Slingshot auth",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./testing": {
      "bun": "./src/testing.ts",
      "import": "./dist/src/testing.js",
      "types": "./dist/src/testing.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-postgres"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public",
    "tag": "next"
  },
  "files": [
    "dist",
    "drizzle"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --cache"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*"
  },
  "peerDependencies": {
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0"
  },
  "peerDependenciesMeta": {
    "drizzle-orm": {
      "optional": false
    },
    "pg": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0"
  },
  "engines": {
    "node": ">=20"
  }
}
