{
  "name": "@lastshotlabs/slingshot-push",
  "version": "0.1.1",
  "description": "Multi-provider push delivery plugin for Slingshot",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./testing": {
      "bun": "./src/testing.ts",
      "types": "./dist/src/testing.d.ts",
      "import": "./dist/src/testing.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --cache",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "^0.1.0",
    "@lastshotlabs/slingshot-entity": "workspace:*",
    "web-push": "^3.6.7"
  },
  "peerDependencies": {
    "@lastshotlabs/slingshot-notifications": "workspace:*",
    "hono": ">=4.12.12 <5",
    "zod": ">=4.0 <5",
    "pg": "^8.20.0",
    "mongoose": ">=9.0 <10"
  },
  "peerDependenciesMeta": {
    "@lastshotlabs/slingshot-notifications": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/web-push": "^3.6.4"
  }
}
