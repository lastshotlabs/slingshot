{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    "types": ["node", "bun"],
    "tsBuildInfoFile": ".tmp/tsconfig.typecheck.tsbuildinfo",
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": ".",
    "outDir": ".tmp/typecheck",
    "noEmit": false
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../slingshot-core/tsconfig.typecheck.json" },
    { "path": "../runtime-node/tsconfig.typecheck.json" }
  ]
}
