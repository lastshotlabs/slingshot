{
  "name": "@lastshotlabs/slingshot-ssg",
  "version": "0.0.2",
  "description": "Static site generation helpers built on Slingshot SSR",
  "license": "MIT",
  "type": "module",
  "bin": {
    "slingshot-ssg": "./src/cli.ts"
  },
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-ssg"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --cache"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-ssr": "workspace:*"
  },
  "engines": {
    "node": ">=20"
  }
}
