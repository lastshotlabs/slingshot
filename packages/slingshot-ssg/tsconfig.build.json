{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",

    "tsBuildInfoFile": ".tmp/tsconfig.build.tsbuildinfo",
    "declaration": true,
    "paths": {
      "@lastshotlabs/slingshot-core": ["../slingshot-core/dist/src/index.d.ts"],
      "@lastshotlabs/slingshot-ssr": ["../slingshot-ssr/dist/src/index.d.ts"]
    },
    "composite": true
  },
  "include": ["src"],
  "references": [
    { "path": "../slingshot-core/tsconfig.build.json" },
    { "path": "../slingshot-ssr/tsconfig.build.json" }
  ]
}
