{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "outDir": "dist",
    "tsBuildInfoFile": ".tmp/tsconfig.build.tsbuildinfo",
    "rootDir": ".",
    "skipLibCheck": true,
    "paths": {
      // Point at sibling-package BUILT declarations during this build, not
      // source. Pointing at src/ would pull .ts files into this package's
      // compilation, violating rootDir. The dist .d.ts files are
      // sufficient — we only need the type surface here.
      "@lastshotlabs/slingshot-core": ["../slingshot-core/dist/src/index.d.ts"],
      "@lastshotlabs/slingshot-permissions": ["../slingshot-permissions/dist/src/index.d.ts"],
      "@lastshotlabs/slingshot-ssr": ["../slingshot-ssr/dist/src/index.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
