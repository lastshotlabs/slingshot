{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "outDir": "dist",
    "tsBuildInfoFile": ".tmp/tsconfig.build.tsbuildinfo",
    "rootDir": ".",
    "skipLibCheck": true,
    "paths": {
      // Point at slingshot-ssr's BUILT declarations during this build, not
      // its source. Pointing at src/ would pull slingshot-ssr's .ts files
      // into this package's compilation, violating rootDir. The dist .d.ts
      // file is sufficient — we only need the type surface here.
      "@lastshotlabs/slingshot-ssr": ["../slingshot-ssr/dist/src/index.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
