{
  "name": "@lastshotlabs/slingshot-webhooks",
  "version": "0.0.3",
  "description": "Inbound and outbound webhook plugin with entity-backed endpoints for Slingshot",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "bun": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./testing": {
      "bun": "./dist/src/testing.js",
      "types": "./dist/src/testing.d.ts",
      "import": "./dist/src/testing.js"
    },
    "./manifest": {
      "bun": "./dist/src/manifest/webhooksManifest.js",
      "types": "./dist/src/manifest/webhooksManifest.d.ts",
      "import": "./dist/src/manifest/webhooksManifest.js"
    },
    "./bullmq": {
      "bun": "./dist/src/queues/bullmq.js",
      "types": "./dist/src/queues/bullmq.d.ts",
      "import": "./dist/src/queues/bullmq.js"
    },
    "./errors": {
      "bun": "./dist/src/errors.js",
      "types": "./dist/src/errors.d.ts",
      "import": "./dist/src/errors.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lastshotlabs/slingshot.git",
    "directory": "packages/slingshot-webhooks"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "bun test",
    "coverage": "bun test --coverage",
    "test:unit": "bun test tests/unit",
    "test:integration": "bun test tests/integration",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --cache"
  },
  "dependencies": {
    "@lastshotlabs/slingshot-core": "workspace:*"
  },
  "peerDependencies": {
    "@lastshotlabs/slingshot-entity": "workspace:*",
    "hono": ">=4.12.14 <5",
    "zod": ">=4.0 <5",
    "pg": "^8.20.0",
    "mongoose": ">=9.0 <10"
  },
  "peerDependenciesMeta": {
    "@lastshotlabs/slingshot-entity": {
      "optional": true
    },
    "bullmq": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20"
  }
}
