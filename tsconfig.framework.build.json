{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "declaration": true,
    "composite": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "incremental": true,
    "tsBuildInfoFile": ".tmp/tsconfig.framework.build.tsbuildinfo",
    "paths": {
      "@framework/*": ["./src/framework/*"],
      "@lib/*": ["./src/lib/*"],
      "@config/*": ["./src/config/*"],
      "@app": ["./src/app.ts"],
      "@lastshotlabs/slingshot-core": ["./packages/slingshot-core/dist/src/index.d.ts"],
      "@lastshotlabs/slingshot-core/faker": ["./packages/slingshot-core/dist/src/faker/index.d.ts"],
      "@lastshotlabs/slingshot-core/testing": ["./packages/slingshot-core/dist/src/testing.d.ts"],
