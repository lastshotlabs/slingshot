    { "path": "./packages/slingshot-m2m/tsconfig.build.json" },
    { "path": "./packages/slingshot-scim/tsconfig.build.json" },
    { "path": "./packages/slingshot-oidc/tsconfig.build.json" },
    { "path": "./packages/slingshot-oauth/tsconfig.build.json" },
    { "path": "./packages/slingshot-webhooks/tsconfig.build.json" },
    { "path": "./packages/slingshot-push/tsconfig.build.json" },
    { "path": "./packages/slingshot-entity/tsconfig.build.json" },
    { "path": "./packages/slingshot-infra/tsconfig.build.json" },
    { "path": "./packages/slingshot-search/tsconfig.build.json" },
    { "path": "./packages/slingshot-ssg/tsconfig.build.json" },
    { "path": "./packages/slingshot-ssr/tsconfig.build.json" },
    { "path": "./packages/slingshot-embeds/tsconfig.build.json" },
    { "path": "./packages/slingshot-emoji/tsconfig.build.json" },
    { "path": "./packages/slingshot-gifs/tsconfig.build.json" },
    { "path": "./packages/slingshot-image/tsconfig.build.json" },
    { "path": "./packages/slingshot-mail/tsconfig.build.json" },
    { "path": "./packages/slingshot-bullmq/tsconfig.build.json" },
